# libzip - platform-specific sources.  Mirrors the WIN32 branch in
# 3rdparty/libzip/CMakeLists.txt: the *_win32 sources use Win32-only
# APIs (CryptGenRandom, _wopen, etc.) and the unix sources reference
# /dev/urandom and POSIX tempfile APIs.
#
# AES-encrypted-archive support is intentionally not built on either
# platform -- pcsx2 never opens encrypted archives (CHD/cso/iso are
# never WinZip-AES) so zip_winzip_aes.c, zip_source_winzip_aes_*.c,
# and zip_crypto_win.c (the bcrypt-backed AES implementation) are
# omitted.  This also means we don't need -lbcrypt on Windows.
# zip_random_win32.c uses CryptGenRandom from <wincrypt.h> in advapi32,
# linked by default on both MSVC and mingw, so no LIBS edit is needed.
# Keep these two lists in sync with LIBZIP_PLATFORM_SOURCES in
# 3rdparty/libzip/CMakeLists.txt.
ifeq ($(IS_WINDOWS), 1)
SOURCES_C += \
	$(DEPS_DIR)/libzip/libzip/lib/zip_random_win32.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_win32.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_win32_ansi.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_win32_named.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_win32_utf16.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_win32_utf8.c
else
SOURCES_C += \
	$(DEPS_DIR)/libzip/libzip/lib/zip_random_unix.c \
	$(DEPS_DIR)/libzip/libzip/lib/zip_source_file_stdio_named.c
endif

# D3D12MemAlloc (Windows only)
ifeq ($(IS_WINDOWS), 1)
SOURCES_CXX += $(DEPS_DIR)/d3d12memalloc/src/D3D12MemAlloc.cpp
endif

