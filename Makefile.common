# ============================================================================
# parallel-gs + Granite (Vulkan only)
# ============================================================================
ifeq ($(HAVE_VULKAN), 1)
# parallel-gs core
SOURCES_CXX += \
	$(PGS_DIR)/gs/gs_interface.cpp \
	$(PGS_DIR)/gs/gs_renderer.cpp \
	$(PGS_DIR)/gs/gs_util.cpp \
	$(PGS_DIR)/gs/page_tracker.cpp

# Granite math
# aabb, frustum, interpolation, math, transforms are excluded: nm on the build
# shows none of their defined symbols are referenced by anything we link in
# (paraLLEl-GS does not use Granite's scene-graph / culling / colour helpers).
# muglm is the only actually-used math TU.
SOURCES_CXX += \
	$(GRANITE_DIR)/math/muglm/muglm.cpp

# Granite util
# cli_parser, dynamic_library, message_queue are excluded: their consumers
# (viewer/slangmosh tools, audio mixer, ffmpeg decode, thread group, wsi_dxgi)
# are not built in the libretro core.
# string_helpers and thread_priority are also excluded: nm shows none of their
# defined symbols are referenced anywhere we link in.
# timeline_trace_file is needed because Granite's vulkan/device.cpp calls
# allocate_event/submit_event directly on system_handles.timeline_trace_file
# (only the GRANITE_SCOPED_TIMELINE_EVENT macros are GRANITE_SHIPPING-gated).
SOURCES_CXX += \
	$(GRANITE_DIR)/util/aligned_alloc.cpp \
	$(GRANITE_DIR)/util/arena_allocator.cpp \
	$(GRANITE_DIR)/util/environment.cpp \
	$(GRANITE_DIR)/util/logging.cpp \
	$(GRANITE_DIR)/util/slab_allocator.cpp \
	$(GRANITE_DIR)/util/thread_id.cpp \
	$(GRANITE_DIR)/util/thread_name.cpp \
	$(GRANITE_DIR)/util/timeline_trace_file.cpp \
	$(GRANITE_DIR)/util/timer.cpp

# Granite vulkan
# wsi.cpp and wsi_dxgi.cpp are excluded: the libretro core integrates with the
# frontend's swapchain via retro_vulkan_* callbacks (pgs_create_device etc.)
# and does not call any Vulkan::WSI methods. Excluding wsi.cpp also avoids the
# vkAcquireFullScreenExclusiveModeEXT / vkGetPhysicalDeviceSurfacePresentModes2EXT
# undefineds it pulls in.
# pipeline_event is excluded: nm shows nothing references EventHolder /
# EventHolderDeleter externally; paraLLEl-GS does not use Vulkan events for
# inter-pass synchronisation.
SOURCES_CXX += \
	$(GRANITE_DIR)/vulkan/buffer.cpp \
	$(GRANITE_DIR)/vulkan/buffer_pool.cpp \
	$(GRANITE_DIR)/vulkan/command_buffer.cpp \
	$(GRANITE_DIR)/vulkan/command_pool.cpp \
	$(GRANITE_DIR)/vulkan/context.cpp \
	$(GRANITE_DIR)/vulkan/cookie.cpp \
	$(GRANITE_DIR)/vulkan/descriptor_set.cpp \
	$(GRANITE_DIR)/vulkan/device.cpp \
	$(GRANITE_DIR)/vulkan/event_manager.cpp \
	$(GRANITE_DIR)/vulkan/fence.cpp \
	$(GRANITE_DIR)/vulkan/fence_manager.cpp \
	$(GRANITE_DIR)/vulkan/image.cpp \
	$(GRANITE_DIR)/vulkan/indirect_layout.cpp \
	$(GRANITE_DIR)/vulkan/memory_allocator.cpp \
	$(GRANITE_DIR)/vulkan/pipeline_cache.cpp \
	$(GRANITE_DIR)/vulkan/query_pool.cpp \
	$(GRANITE_DIR)/vulkan/render_pass.cpp \
	$(GRANITE_DIR)/vulkan/rtas.cpp \
	$(GRANITE_DIR)/vulkan/sampler.cpp \
	$(GRANITE_DIR)/vulkan/semaphore.cpp \
	$(GRANITE_DIR)/vulkan/semaphore_manager.cpp \
	$(GRANITE_DIR)/vulkan/shader.cpp \
	$(GRANITE_DIR)/vulkan/texture/texture_format.cpp

# Granite volk (C, single TU)
SOURCES_C += $(GRANITE_DIR)/third_party/volk/volk.c
endif

