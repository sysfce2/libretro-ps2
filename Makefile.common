SOURCES_CXX :=
SOURCES_C   :=
SOURCES_ASM :=

# ----------------------------------------------------------------------------
# Directories
# ----------------------------------------------------------------------------
DEPS_DIR          := $(CORE_DIR)/3rdparty
LIBRETRO_DIR      := $(CORE_DIR)/libretro
LIBRETRO_COMM_DIR := $(LIBRETRO_DIR)/libretro-common
COMMON_DIR        := $(CORE_DIR)/common
LRPS2_DIR         := $(CORE_DIR)/pcsx2
PGS_DIR           := $(LRPS2_DIR)/GS/parallel-gs
GRANITE_DIR       := $(PGS_DIR)/Granite

# ----------------------------------------------------------------------------
# Include flags
# ----------------------------------------------------------------------------
# Mirrors what the cmake LIBRETRO=ON build resolves to for pcsx2_libretro/PCSX2/
# common targets.  Order matters: project headers first, then 3rdparty.
INCFLAGS := \
	-I$(CORE_DIR) \
	-I$(LRPS2_DIR) \
	-I$(LRPS2_DIR)/x86 \
	-I$(COMMON_DIR) \
	-I$(COMMON_DIR)/include \
	-I$(LIBRETRO_DIR) \
	-I$(LIBRETRO_COMM_DIR)/include \
	-I$(DEPS_DIR) \
	-I$(DEPS_DIR)/include \
	-I$(DEPS_DIR)/xbyak \
	-I$(DEPS_DIR)/rapidyaml/rapidyaml/src \
	-I$(DEPS_DIR)/rapidyaml/rapidyaml/ext/c4core/src \
	-I$(DEPS_DIR)/rapidyaml/rapidyaml/ext/c4core/src/c4/ext/fast_float/include \
	-I$(DEPS_DIR)/cpuinfo/include \
	-I$(DEPS_DIR)/cpuinfo/src \
	-I$(DEPS_DIR)/cpuinfo/deps/clog/include \
	-I$(DEPS_DIR)/zlib \
	-I$(DEPS_DIR)/zstd/zstd/lib \
	-I$(DEPS_DIR)/lz4/lz4/lib \
	-I$(DEPS_DIR)/libpng \
	-I$(DEPS_DIR)/libzip \
	-I$(DEPS_DIR)/libzip/libzip/lib \
	-I$(DEPS_DIR)/libzip/private \
	-I$(DEPS_DIR)/chdr/libchdr/include \
	-I$(DEPS_DIR)/lzma/include \
	-I$(DEPS_DIR)/d3d12memalloc/include

ifeq ($(HAVE_OPENGL), 1)
	INCFLAGS += -I$(DEPS_DIR)/glad/include
endif

ifeq ($(HAVE_VULKAN), 1)
	INCFLAGS += \
		-I$(DEPS_DIR)/vulkan-headers/include \
		-I$(DEPS_DIR)/glslang/glslang \
		-I$(DEPS_DIR)/glslang/include \
		-I$(GRANITE_DIR)/util \
		-I$(GRANITE_DIR)/math \
		-I$(GRANITE_DIR)/vulkan \
		-I$(GRANITE_DIR)/application/global \
		-I$(GRANITE_DIR)/third_party/volk \
		-I$(PGS_DIR)/gs
endif

# ----------------------------------------------------------------------------
# Defines mirroring cmake's LIBRETRO=ON Windows build
# ----------------------------------------------------------------------------
ifeq ($(HAVE_OPENGL), 1)
	ifeq ($(GLES3), 1)
		FLAGS += -DHAVE_OPENGLES -DHAVE_OPENGLES3 -DENABLE_OPENGL
	else ifeq ($(GLES), 1)
		FLAGS += -DHAVE_OPENGLES -DHAVE_OPENGLES2 -DENABLE_OPENGL
	else
		FLAGS += -DHAVE_OPENGL -DCORE -DENABLE_OPENGL
	endif
endif

ifeq ($(HAVE_VULKAN), 1)
	FLAGS += -DHAVE_VULKAN -DENABLE_VULKAN -DHAVE_PARALLEL_GS \
		 -DGRANITE_SHIPPING
endif

ifeq ($(NEED_THREADING), 1)
	FLAGS += -DWANT_THREADING -DHAVE_THREADS
endif

ifeq ($(FRONTEND_SUPPORTS_RGB565), 1)
	FLAGS += -DFRONTEND_SUPPORTS_RGB565
endif

CFLAGS   += $(FLAGS)
CXXFLAGS += $(FLAGS)

# ============================================================================
# libretro-common (C)
# ============================================================================
SOURCES_C += \
	$(LIBRETRO_COMM_DIR)/compat/compat_posix_string.c \
	$(LIBRETRO_COMM_DIR)/compat/compat_strl.c \
	$(LIBRETRO_COMM_DIR)/compat/fopen_utf8.c \
	$(LIBRETRO_COMM_DIR)/encodings/encoding_utf.c \
